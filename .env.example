DATABASE_URL=postgresql://bluestock:bluestock@127.0.0.1:5432/bluestock
REDIS_URL=redis://127.0.0.1:6379/0

# Optional importer defaults
DATASET_DIR=dataset
IMPORT_BATCH_SIZE=1000
POSTGRES_POOL_SIZE=10

APP_JWT_SECRET=replace-with-a-long-random-secret
ADMIN_EMAIL=admin@bluestock.local
ADMIN_PASSWORD=change-admin-password

# React/Vite frontend
VITE_API_BASE_URL=http://127.0.0.1:8000

# Deployment notes:
# - On Vercel + Neon, set DATABASE_URL to Neon's pooled connection string.
# - Set REDIS_URL to a shared Redis provider such as Upstash for distributed rate limits.
